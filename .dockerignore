# Build artifacts
dist/
node_modules/
.git/
.gitignore
.gitattributes

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and temp files
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
_tmp/
_upload/

# Documentation that does not need to be in the image
README*.md
LICENSE
*.md

# CI / deploy configs not relevant to the docker build
netlify.toml
vercel.json
.github/
.gitlab-ci.yml

# Docker files themselves (avoid recursive context)
Dockerfile*
docker-compose*.yml
.dockerignore
